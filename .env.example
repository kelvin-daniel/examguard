# Local development defaults — copy to .env to start.
# DO NOT commit .env (it's gitignored).

# --- Required ---

# Local SQLite for dev. For production deployment, replace with libsql://...
DATABASE_URL="file:./dev.db"

# Comma-separated list of emails that auto-bootstrap to admin (active) on first
# registration. Add your school admin email here BEFORE they sign up.
# Example: ADMIN_EMAILS="principal@yourschool.edu,it@yourschool.edu"
ADMIN_EMAILS=""

# --- Production-only (leave empty for local dev) ---

# Turso (free SQLite-compatible cloud DB). See README for setup.
TURSO_AUTH_TOKEN=""

# Resend (free 3,000 emails/month). Without an API key, emails just log to stdout.
RESEND_API_KEY=""
EMAIL_FROM="ExamGuard <onboarding@resend.dev>"

# Public URL of the deployed app — used in email links.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cloudflare R2 (free 10 GB, free egress) for screenshots + question images.
# Without these, both fall back to base64 in the DB — fine for early beta but
# will balloon Turso storage past ~10 active classes. Set ALL FIVE to enable.
R2_ENDPOINT=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_URL=""
